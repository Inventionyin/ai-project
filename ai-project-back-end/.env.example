APP_NAME=ai-test-platform
ENV=local
DEBUG=false

API_PREFIX=/api

DATABASE_URL="postgresql+asyncpg://postgres:123456@localhost:5432/ai_test_platform"

CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
JWT_SECRET_KEY=dev_secret_change_me_please_32chars_min_123456
RUNNER_WORKSPACE_ROOT=D:/ai-test-platform-runners
RUNNER_PYTHON_EXECUTABLE=python
RUNNER_ALLURE_COMMAND=allure

LLM_PROVIDER=longcat
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_MODEL=LongCat-Flash-Lite
LLM_API_KEY=replace_with_your_local_key
